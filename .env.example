ADMIN_PASSWORD=change-me
COOKIE_SECRET=change-me-to-a-long-random-string
DATABASE_URL=postgresql://user:pass@host/db

# Tigris / S3-compatible object storage (required for uploads)
# On Fly.io: set automatically by `flyctl storage create`
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL_S3=
AWS_REGION=auto
BUCKET_NAME=svums-uploads
