# ─── Required ───────────────────────────────────────────────────
ADMIN_PASSWORD=change-me
COOKIE_SECRET=change-me-to-a-long-random-string-at-least-24-chars

# ─── Database ───────────────────────────────────────────────────
# SQLite (default, good for single-server setups):
#   Leave commented — the app uses SQLite in /app/data/ by default.
# PostgreSQL (recommended for production):
#   DATABASE_URL=postgresql://user:pass@host:5432/svums

# ─── Public URL (for links in emails) ──────────────────────────
# PUBLIC_BASE_URL=https://your-domain.com

# ─── S3 Storage (optional, for file uploads) ───────────────────
# Without these, upload/download features are disabled.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_ENDPOINT_URL_S3=
# AWS_REGION=auto
# BUCKET_NAME=svums-uploads

# ─── Geocoding (required for the member map) ───────────────────
# Sign up at https://developer.here.com → "Discover HERE REST APIs"
# and create a freemium project. 250k requests/month free, no card.
# HERE_API_KEY=

# ─── Analytics (optional) ──────────────────────────────────────
# POSTHOG_KEY=
# POSTHOG_HOST=

# ─── Advanced ──────────────────────────────────────────────────
# FORWARDED_ALLOW_IPS=127.0.0.1,::1
# LOG_LEVEL=INFO
